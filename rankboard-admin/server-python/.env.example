# Copy this file to ".env" (same folder) and fill in your real values.
# The .env file is read automatically on server start. NEVER commit .env.

# ── Server ──────────────────────────────────────────────────────────
# PORT          — port the API listens on (default 4000)
# JWT_SECRET    — signing key for auth tokens. REQUIRED: there is NO fallback,
#                 so the server refuses to start until this is set. Use a long
#                 random value (e.g. `python -c "import secrets;print(secrets.token_urlsafe(48))"`).
# APP_URL       — frontend base URL used in invite-email links.
# DEBUG         — set true ONLY in development to enable /docs, /redoc,
#                 /openapi.json. Leave false/unset in production.
# CORS_ORIGINS  — comma-separated browser origins allowed to call the API.
#                 Defaults to APP_URL. NEVER use "*".
# PORT=4000
JWT_SECRET=change-me-to-a-long-random-string
APP_URL=http://localhost:5173
# DEBUG=false
# CORS_ORIGINS=http://localhost:5173

# ── DataForSEO (automatic rank checks) ──────────────────────────────
# Leave LOGIN/PASSWORD empty for free SIMULATED mode (random-walk numbers,
# clearly labeled). Set both to do real Google lookups.
DATAFORSEO_LOGIN=your-dataforseo-login
DATAFORSEO_PASSWORD=your-dataforseo-password

# Optional — uncomment to test against DataForSEO's free mock-data sandbox:
# DATAFORSEO_BASE=https://sandbox.dataforseo.com

# Optional tuning:
# RANK_LOCATION_CODE=2356        # 2356 = India
# RANK_LANGUAGE=en
# RANK_CHECK_DEPTH=30            # how deep into Google to look (pages of 10)

# ── Moz API (domain Authority panel) ────────────────────────────────
# Token for the modern JSON-RPC API (the x-moz-token header, NOT the legacy
# Access ID / Secret Key). Powers the per-project Authority panel. Leave empty
# to disable it; quota is tiny, so Moz is only called on an explicit refresh.
MOZ_API_TOKEN=

# ── Resend (transactional email) ────────────────────────────────────
# RESEND_API_KEY — API key for sending invite / onboarding emails via
#   https://api.resend.com/emails. Leave empty/unset to keep emails in the dev
#   outbox (the `emails` table) instead of actually sending them. Get a key at
#   resend.com.
# EMAIL_FROM     — sender address. Custom-domain senders must be verified in
#   Resend first. Defaults to "RankBoard <onboarding@resend.dev>".
RESEND_API_KEY=
# EMAIL_FROM=RankBoard <onboarding@resend.dev>

# ── Google Analytics 4 (GA4 traffic panel) ──────────────────────────
# Path to the Google service-account JSON key file. Leave empty to disable the
# GA4 traffic panel (the provider returns a clear "not configured" result
# instead of crashing). Each project stores its own GA4 property ID in the DB.
GOOGLE_SERVICE_ACCOUNT_JSON=path/to/service-account.json    

    